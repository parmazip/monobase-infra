# Remote State Configuration (Google Cloud Storage)
#
# IMPORTANT: This is an EXAMPLE file. To use remote state:
# 1. Create a GCS bucket for Terraform state
# 2. Copy this file to backend.tf
# 3. Update the bucket name
# 4. Run: terraform init -migrate-state
#
# To create a state bucket:
# gsutil mb -p YOUR_PROJECT_ID -l us-central1 gs://YOUR_BUCKET_NAME
# gsutil versioning set on gs://YOUR_BUCKET_NAME

terraform {
  backend "gcs" {
    bucket = "your-terraform-state-bucket"  # Change this
    prefix = "monobase/production-gke"      # Or: monobase/${var.cluster_name}

    # Optional: Enable state locking (recommended for team environments)
    # Note: Requires Firestore Native mode enabled in the project
    # enable_state_locking = true
  }
}

# Example bucket naming conventions:
# - Single cluster: terraform-state-monobase-prod
# - Multi-cluster: terraform-state-${organization}
# - Multi-tenant: terraform-state-monobase
#
# Prefix patterns:
# - By environment: clusters/production/
# - By cluster name: clusters/${cluster_name}/
# - By region: clusters/us-central1/${cluster_name}/
